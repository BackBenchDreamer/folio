---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ui/ProjectCard.astro';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const sorted = allProjects.sort((a, b) => a.data.priority - b.data.priority);

const mediaProjects = sorted.filter(p => p.data.variant === 'media');
const iconProjects  = sorted.filter(p => p.data.variant === 'icon');
---

<BaseLayout
  title="Projects"
  description="Selected engineering and creative projects."
>
  <div class="projects-page section-spacing">
    <div class="projects-inner">
      <header class="page-header">
        <h1 class="page-title">Projects</h1>
        <p class="page-desc">Selected work — engineering and creative.</p>
      </header>

      <!-- Featured work — media cards -->
      {mediaProjects.length > 0 && (
        <section aria-labelledby="featured-work-label">
          <h2 id="featured-work-label" class="section-label">Featured Work</h2>
          <div class="media-grid">
            {mediaProjects.map(p => (
              <ProjectCard
                title={p.data.title}
                description={p.data.description}
                variant={p.data.variant}
                mediaType={p.data.mediaType}
                thumbnail={p.data.thumbnail}
                mediaSrc={p.data.mediaSrc}
                stack={p.data.stack}
                github={p.data.github}
                demo={p.data.demo}
              />
            ))}
          </div>
        </section>
      )}

      <!-- Side quests — icon cards -->
      {iconProjects.length > 0 && (
        <section class="side-quests" aria-labelledby="side-quests-label">
          <h2 id="side-quests-label" class="section-label">Side Quests</h2>
          <div class="icon-grid">
            {iconProjects.map(p => (
              <ProjectCard
                title={p.data.title}
                description={p.data.description}
                variant={p.data.variant}
                mediaType={p.data.mediaType}
                thumbnail={p.data.thumbnail}
                mediaSrc={p.data.mediaSrc}
                stack={p.data.stack}
                github={p.data.github}
                demo={p.data.demo}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .projects-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .page-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  .section-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .side-quests {
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .media-grid {
      grid-template-columns: 1fr;
    }

    .icon-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    }
  }
</style>
