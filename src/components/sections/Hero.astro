---
import { siteConfig } from '@/config/site.config';
import LiveTime from '@/components/ui/LiveTime.astro';
---

<section class="hero section-spacing" aria-labelledby="hero-name">
  <div class="hero-inner">

    <!-- Name -->
    <h1 id="hero-name" class="hero-name">{siteConfig.displayName}</h1>

    <!-- Role -->
    <p class="hero-role">{siteConfig.role}</p>

    <!-- Intro -->
    <p class="hero-intro">{siteConfig.intro}</p>

    <!-- Section CTAs -->
    <nav class="hero-nav" aria-label="Site sections">
      <a href="/projects" class="hero-nav-link">Projects →</a>
      <a href="/art"      class="hero-nav-link">Art →</a>
      <a href="/blog"     class="hero-nav-link">Writing →</a>
    </nav>

    <!-- Meta row: location, time -->
    <div class="hero-meta">
      <span class="hero-location">{siteConfig.location}</span>
      <span class="meta-sep" aria-hidden="true">·</span>
      <LiveTime />
      <span class="meta-sep" aria-hidden="true">·</span>
      <span class="hero-status">{siteConfig.availability}</span>
    </div>

    <!-- Social links + resume -->
    <div class="hero-actions">
      <div class="social-links">
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="GitHub"
        >GitHub</a>
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="LinkedIn"
        >LinkedIn</a>
        <a
          href={siteConfig.social.x}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="X"
        >X</a>
        {siteConfig.social.instagram && (
          <a
            href={siteConfig.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Instagram"
          >Instagram</a>
        )}
      </div>
      <a
        href={siteConfig.social.resume}
        class="resume-btn"
        download
        aria-label="Download resume"
      >Resume ↓</a>
    </div>

  </div>
</section>

<style>
  .hero {
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-name {
    font-size: clamp(var(--text-3xl), 8vw, var(--text-5xl));
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  .hero-intro {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  /* Section CTAs */
  .hero-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.125rem;
    margin-bottom: 2.5rem;
  }

  .hero-nav-link {
    display: inline-block;
    padding: 0.4rem 0.75rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      color var(--duration-default) var(--easing-default),
      border-color var(--duration-default) var(--easing-default),
      background-color var(--duration-default) var(--easing-default);
  }

  .hero-nav-link:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
    background-color: var(--color-surface);
  }

  /* Meta */
  .hero-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .hero-location,
  .hero-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .meta-sep {
    color: var(--color-border);
    font-size: var(--text-xs);
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .social-link {
    display: inline-block;
    padding: 0.375rem 0.625rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: color var(--duration-default), background-color var(--duration-default);
  }

  .social-link:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface);
  }

  .resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-primary);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      color var(--duration-default),
      background-color var(--duration-default),
      border-color var(--duration-default);
  }

  .resume-btn:hover {
    background-color: var(--color-surface-raised);
    border-color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .hero-meta {
      gap: 0.375rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .hero-nav {
      gap: 0.375rem;
    }
  }
</style>
