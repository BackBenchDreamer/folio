---
/**
 * ProjectCard.astro
 * Two display modes:
 *   variant="media" — full-bleed video or image card (gaievskyi-style)
 *   variant="icon"  — compact app-icon card (kaiyu-style)
 */
interface Props {
  title: string;
  description: string;
  variant: 'media' | 'icon';
  mediaType: 'video' | 'image';
  thumbnail: string;
  mediaSrc?: string;
  stack: string[];
  github?: string;
  demo?: string;
}

const {
  title,
  description,
  variant = 'media',
  mediaType = 'image',
  thumbnail,
  mediaSrc,
  stack,
  github,
  demo,
} = Astro.props;

const thumbPath = `/images/projects/${thumbnail}`;
const hasVideo = variant === 'media' && mediaType === 'video' && mediaSrc;
---

{variant === 'media' ? (
  <article class="card card-media">
    <!-- Media area -->
    <div class="card-media-wrapper">
      {hasVideo ? (
        <video
          class="card-video"
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster={thumbPath}
          aria-label={`${title} demo video`}
        >
          <source src={mediaSrc} type="video/mp4" />
          <!-- HLS fallback for Safari -->
          {mediaSrc?.endsWith('.m3u8') && (
            <source src={mediaSrc} type="application/x-mpegURL" />
          )}
        </video>
      ) : (
        <img
          src={thumbPath}
          alt={`${title} screenshot`}
          loading="lazy"
          width="800"
          height="500"
          class="card-image"
        />
      )}

      <!-- Hover overlay -->
      <div class="card-overlay" aria-hidden="true">
        <p class="overlay-desc">{description}</p>
        <ul class="overlay-stack" role="list">
          {stack.slice(0, 4).map(s => (
            <li class="overlay-badge">{s}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Card footer -->
    <footer class="card-footer">
      <h3 class="card-title">{title}</h3>
      <div class="card-links">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="card-link"
            aria-label={`${title} on GitHub`}
          >
            GitHub
          </a>
        )}
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="card-link"
            aria-label={`${title} live demo`}
          >
            Demo ↗
          </a>
        )}
      </div>
    </footer>
  </article>
) : (
  <article class="card card-icon">
    <div class="icon-thumb-wrapper">
      <img
        src={thumbPath}
        alt={`${title} icon`}
        width="80"
        height="80"
        loading="lazy"
        class="icon-thumb"
      />
    </div>
    <span class="icon-title">{title}</span>
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="icon-link"
        aria-label={`${title} on GitHub`}
      >
        ↗
      </a>
    )}
  </article>
)}

<style>
  /* ── Media card ────────────────────────────────────── */
  .card-media {
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color var(--duration-default);
  }

  .card-media:hover {
    border-color: var(--color-text-muted);
  }

  .card-media-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background-color: var(--color-surface-raised);
  }

  .card-video,
  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Stop autoplay on reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .card-video {
      animation-play-state: paused;
    }
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--duration-default) var(--easing-default);
  }

  .card-media:hover .card-overlay {
    opacity: 1;
  }

  .overlay-desc {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.9);
    line-height: var(--leading-snug);
    margin-bottom: 0.5rem;
  }

  .overlay-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
  }

  .overlay-badge {
    padding: 0.1em 0.45em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius-full);
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1rem;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .card-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
  }

  .card-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-default);
  }

  .card-link:hover {
    color: var(--color-text-primary);
  }

  /* ── Icon card ─────────────────────────────────────── */
  .card-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    text-align: center;
    position: relative;
    transition: border-color var(--duration-default), background-color var(--duration-default);
  }

  .card-icon:hover {
    border-color: var(--color-text-muted);
    background-color: var(--color-surface-raised);
  }

  .icon-thumb-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    overflow: hidden;
    background-color: var(--color-surface-raised);
    flex-shrink: 0;
  }

  .icon-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .icon-title {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    word-break: break-word;
  }

  .icon-link {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    opacity: 0;
    transition: opacity var(--duration-default);
  }

  .card-icon:hover .icon-link {
    opacity: 1;
  }
</style>
